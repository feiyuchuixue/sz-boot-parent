<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sz.admin.system.mapper.SysDataScopeMapper">
    <!-- 通用映射 -->
    <resultMap id="BaseResultMap" type="com.sz.admin.system.pojo.po.SysDataScope">
        <id column="id" property="id"/>
        <result column="relation_type_cd" property="relationTypeCd"/>
        <result column="relation_id" property="relationId"/>
        <result column="options" property="options"/>
        <result column="create_id" property="createId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, relation_type_cd, relation_id, options, create_id, create_time
    </sql>

</mapper>
